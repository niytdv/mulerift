# ===========================================
# MULERIFT PRODUCTION ENVIRONMENT VARIABLES
# ===========================================

# REQUIRED: Groq API Key for AI Chatbot
# Get your key from: https://console.groq.com/
# Without this, the AI chatbot will not work
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL: Node Environment
# Railway automatically sets this to 'production'
NODE_ENV=production

# OPTIONAL: Server Port
# Railway automatically provides this via $PORT
# Default: 3000 for local development
PORT=3000

# ===========================================
# RAILWAY DEPLOYMENT NOTES
# ===========================================
# 1. Set GROQ_API_KEY in Railway dashboard under Variables
# 2. PORT and NODE_ENV are automatically set by Railway
# 3. Python 3.11 is pre-installed via nixpacks.toml
# 4. No database configuration needed (stateless app)
